NODE_ENV=production
PORT=4000
HOST=0.0.0.0

DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=replace_with_secure_password
DB_NAME=GAK
DB_SSL_MODE=required
DB_SSL_REJECT_UNAUTHORIZED=true
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
SERVICE_NAME=gak-api
LOG_LEVEL=info

JWT_SECRET=replace_with_at_least_32_char_secret
JWT_SECRET_PREVIOUS=
JWT_EXPIRES_IN=12h
JWT_ENFORCE_CLAIMS=true
JWT_ISSUER=gak-backend
JWT_AUDIENCE=gak-client

ENFORCE_HTTPS=true
FRONTEND_URL=https://your-frontend-domain
CORS_ORIGINS=https://your-frontend-domain
FRONTEND_ALLOWED_REDIRECTS=https://your-frontend-domain

OAUTH_STATE_SECRET=replace_with_at_least_32_char_secret
OAUTH_STATE_TTL_MS=600000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api-domain/api/integrations/google/callback
GOOGLE_ALLOWED_REDIRECT_URIS=https://your-api-domain/api/integrations/google/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/fitness.activity.read,https://www.googleapis.com/auth/fitness.activity.write,https://www.googleapis.com/auth/fitness.body.read
TOKEN_ENCRYPTION_KEYS=v1:replace_with_32_plus_char_secret

OPENAI_API_KEY=
NUTRITION_ANALYSIS_MODE=dummy
NUTRITION_DASHBOARD_MODE=

ACADEMIA_BASE_URL=https://academia.srmist.edu.in
ACADEMIA_SCRAPE_MODE=playwright
ACADEMIA_RETRY_ATTEMPTS=3
ACADEMIA_RETRY_BACKOFF_MS=1200
ACADEMIA_TIMETABLE_URL=https://academia.srmist.edu.in/#Page:My_Time_Table_2023_24
ACADEMIA_MARKS_URL=https://academia.srmist.edu.in/#Page:My_Marks
ACADEMIA_ATTENDANCE_URL=https://academia.srmist.edu.in/#Page:My_Attendance
ACADEMIA_ZOHO_URI_PREFIX=/accounts/p/10002227248
ACADEMIA_SIGNIN_URL=
ACADEMIA_TERMINATE_SESSIONS_ON_LIMIT=auto
ACADEMIA_PLAYWRIGHT_HEADLESS=true
ACADEMIA_FORCE_HEADLESS_SYNC=true
ACADEMIA_STATE_DIR=/var/lib/gak/academia-state
ACADEMIA_STORAGE_STATE_PATH=
ACADEMIA_SPA_SETTLE_MS=15000

ENABLE_JOBS=true
WORKER_CONCURRENCY=4
JOB_ATTEMPTS=5
JOB_BACKOFF_MS=30000
JOB_KEEP_COMPLETE_SECONDS=3600
JOB_KEEP_FAILED_SECONDS=86400
QUEUE_DEPTH_INTERVAL_MS=15000
IDEMPOTENCY_WINDOW_SECONDS=300
REDIS_CACHE_TTL_SECONDS=600
BEHAVIOR_CACHE_TTL_SECONDS=900
HISTORY_CACHE_TTL_SECONDS=600
JOBS_ADMIN_TOKEN=replace_with_strong_token
CRON_GMAIL_SYNC=*/10 * * * *
CRON_TOKEN_REFRESH=0 * * * *
CRON_CALENDAR_SYNC=15 * * * *
CRON_FIT_SYNC=*/20 * * * *
CRON_ACADEMIC_CLEANUP=5 * * * *
CRON_ACADEMIA_MARKS_ATTENDANCE_SYNC=*/30 * * * *
CRON_ACADEMIA_REPORTS_SYNC=30 3 * * *
CRON_OAUTH_NONCE_CLEANUP=*/30 * * * *
CRON_METRICS_RECOMPUTE=0 2 * * *
FIT_TODAY_REFRESH_MS=300000
FIT_SYNC_INCLUDE_YESTERDAY=true
FIT_SYNC_MAX_USERS=0
